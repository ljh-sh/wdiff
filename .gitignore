# Autotools generated (vendored source)
# NOTE: `configure`, `Makefile.in`, `aclocal.m4` are SHIPPED IN THE
# TARBALL as source files; they are NOT gitignored. `autoreconf -if
# --force` will regenerate `configure` + `Makefile.in` at build
# time, but if CI ever skipped autoreconf (or if the build script
# is wrong), having the tarball-shipped versions in git means the
# build still works.
INSTALL
autom4te.cache/
autotools/
compile
config.guess
config.h.in
config.h.in~
config.log
config.status
config.sub
depcomp
install-sh
libtool
ltmain.sh
missing
test-driver
stamp-h1
# `Makefile` is the file generated by `./configure` (substitute of
# Makefile.in). `Makefile.in` is the input and is tracked above.
Makefile

# CI artefacts
.github/release-output/

